<div id="<%= dom_id quest_item %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Quest:</strong>
    <%= quest_item.quest %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Is done:</strong>
    <%= quest_item.is_done? ? "Yes" : "No" %>
  </div>
</div>
